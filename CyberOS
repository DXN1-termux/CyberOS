#!/bin/bash

# CyberOS VNC Launcher
# Dynamically locate the base path of the repo
CYBEROS_BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CYBEROS_BASE/lib/utils.sh"

log_info "Checking for CyberOS updates..."
git -C "$CYBEROS_BASE" pull --quiet || log_error "Could not fetch updates. Continuing..."

if [ -z "$1" ]; then
    log_error "No port specified. Usage: ./CyberOS [port]"
    exit 1
fi

PORT=$1
# Ensure port is numeric
if [ ! "$PORT" -ge 0 ] 2>/dev/null; then
    log_error "Port must be a number."
    exit 1
fi

# Map port to VNC display number (Simple mapping)
DISPLAY_NUM=$((PORT - 5900))
# If port is below 5900, treat it as display number directly
if [ "$DISPLAY_NUM" -lt 0 ]; then
    DISPLAY_NUM=$PORT
    PORT=$((5900 + DISPLAY_NUM))
fi

log_info "Starting CyberOS on port $PORT (Display :$DISPLAY_NUM)..."

# Ensure core dependencies exist (Using vncserver which is part of tigervnc)
check_dependency vncserver || exit 1

# Kill existing vncserver on this display, if any
vncserver -kill :$DISPLAY_NUM &>/dev/null

# Start the VNC Server with the XFCE desktop
log_info "Initializing VNC server..."
vncserver :$DISPLAY_NUM -depth 24 -name "CyberOS" &>/dev/null

# Verify if the port is listening (Using netstat or lsof)
sleep 2
if command -v lsof >/dev/null; then
    IS_LISTENING=$(lsof -Pi :$PORT -sTCP:LISTEN -t)
elif command -v netstat >/dev/null; then
    IS_LISTENING=$(netstat -tln | grep ":$PORT ")
fi

if [ -n "$IS_LISTENING" ]; then
    log_info "BOOM! CyberOS is live."
    echo -e "[>] Connect your VNC viewer to localhost:$PORT"
else
    log_error "VNC server failed to start on port $PORT. Check ~/.vnc/*.log"
    exit 1
fi
