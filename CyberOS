#!/bin/bash
# ==============================================================================
# CyberOS Launcher - Self-Healing Session Manager (Perfected)
# ==============================================================================

CYBEROS_BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CYBEROS_BASE/lib/utils.sh"

header() {
    echo -e "${CYAN}==================================================${NC}"
    echo -e "           ${BLUE}CYBEROS SESSION INITIALIZER${NC}           "
    echo -e "${CYAN}==================================================${NC}"
}

diagnostic_report() {
    log_step "Pre-flight System Diagnostic"
    
    # 1. Update Check
    log_info "Checking for core updates..."
    git -C "$CYBEROS_BASE" pull --quiet &>/dev/null && log_success "Repository is in sync." || log_warn "Update check skipped (offline mode)."

    # 2. Network Check
    check_internet && log_success "Network synergy established." || log_warn "Limited connectivity mode."

    # 3. Storage Check
    available=$(df -m . | awk 'NR==2 {print $4}')
    [ "$available" -gt 500 ] && log_success "Storage headroom: ${available}MB" || log_warn "Low storage: ${available}MB available."

    # 4. Dependency Verify
    ESSENTIALS="vncserver xfce4-session lsof firefox"
    missing=0
    for tool in $ESSENTIALS; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            log_error "Critical missing tool: $tool"
            missing=$((missing + 1))
        fi
    done
    [ "$missing" -eq 0 ] && log_success "All engine components found." || {
        log_info "Attempting automated engine repair..."
        bash "$CYBEROS_BASE/setup.sh" || { log_error "Engine repair failed."; exit 1; }
    }
}

launch_session() {
    PORT="$1"
    DISPLAY_NUM=$((PORT - 5900))
    if [ "$DISPLAY_NUM" -lt 0 ]; then DISPLAY_NUM="$PORT"; fi

    # Session Conflict Resolution
    if is_port_open "$PORT"; then
        log_warn "Port $PORT is already in use."
        printf "[?] Kill existing VNC session on display :$DISPLAY_NUM? (y/N): "
        read -r confirm
        case "$confirm" in
            [Yy]*)
                log_info "Cleaning display :$DISPLAY_NUM..."
                vncserver -kill :"$DISPLAY_NUM" >/dev/null 2>&1
                rm -rf /tmp/.X"$DISPLAY_NUM"-lock /tmp/.X11-unix/X"$DISPLAY_NUM" >/dev/null 2>&1
                sleep 1
                ;;
            *)
                log_info "Aborting startup to avoid corruption."
                exit 0
                ;;
        esac
    fi

    log_step "Initializing CyberOS on Port $PORT"
    
    # Standard security protocol
    [ ! -f ~/.vnc/passwd ] && {
        log_warn "VNC credentials not found. Initializing..."
        mkdir -p ~/.vnc
        echo "password" | vncpasswd -f > ~/.vnc/passwd
        chmod 600 ~/.vnc/passwd
    }

    # High-performance VNC launch
    vncserver :"$DISPLAY_NUM" -depth 24 -name "CyberOS" -localhost no >/dev/null 2>&1

    # Final Verification
    for i in 1 2 3 4 5; do
        if is_port_open "$PORT"; then
            log_success "SESSION ESTABLISHED!"
            echo -e "${CYAN}--------------------------------------------------${NC}"
            echo -e "${GREEN}VNC Portal:${NC}   localhost:$PORT"
            echo -e "${GREEN}Display:${NC}      :$DISPLAY_NUM"
            echo -e "${GREEN}Identity:${NC}     $(whoami)"
            echo -e "${CYAN}--------------------------------------------------${NC}"
            return 0
        fi
        sleep 1
    done

    log_error "VNC core failed to stabilize on port $PORT."
    exit 1
}

# Main Entry
header
PORT="${1:-5901}"
if ! [ "$PORT" -eq "$PORT" ] 2>/dev/null; then
    log_error "Invalid port: $PORT"
    exit 1
fi

diagnostic_report
launch_session "$PORT"
