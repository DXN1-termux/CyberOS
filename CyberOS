#!/bin/bash
set -e
# ==============================================================================
# CyberOS Launcher - Self-Healing Session Manager (Perfection v10)
# ==============================================================================

CYBEROS_BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CYBEROS_BASE"/lib/config.sh"
source "$CYBEROS_BASE"/lib/utils.sh"

header() {
    echo -e "${CYAN}==================================================${NC}"
    echo -e "           ${BLUE}CYBEROS ENGINE INITIALIZER${NC}            "
    echo -e "           Version: "$CYBEROS_VERSION" ("$CYBEROS_CODENAME")          "
    echo -e "${CYAN}==================================================${NC}"
}

autonomous_doctor() {
    log_step "Autonomous Self-Healing Scan"
    
    # 1. Clean Stale Artifacts
    log_info "Neutralizing stale lock files..."
    rm -f /tmp/.X*-lock /tmp/.X11-unix/X* >/dev/null 2>&1
    
    # 2. Permission Synchronization
    log_info "Synchronizing permission matrix..."
    harden_project
    
    # 3. Component Verification
    if ! validate_installation; then
        log_warn "Engine corruption detected. Triggering recovery..."
        bash "$CYBEROS_BASE"/setup.sh" || { log_error "Recovery failed. Critical system failure."; exit 1; }
    fi
}

launch_session() {
    export port="${1:-"$DEFAULT_VNC_PORT"}"
    export display_num=$((port - 5900))
    [ "$display_num" -lt 0 ] && display_num="$port"

    log_step "Session Negotiation: Port "$port" (Display :"$display_num")"

    # Conflict Resolution Logic
    if is_port_open "$port"; then
        log_warn "Active session detected on port "$port"."
        printf "[?] Intercept and restart session? (y/N): "
        read -r confirm
        case "$confirm" in
            [Yy]*)
                log_info "Terminating display :"$display_num"..."
trap "vncserver -kill :${display_num}; exit 0" SIGTERM SIGINT
                vncserver -kill :"$display_num" >/dev/null 2>&1
                rm -rf /tmp/.X"$display_num"-lock /tmp/.X11-unix/X"$display_num" >/dev/null 2>&1
                sleep 2
                ;;
            *)
                log_info "Bypassing startup. Port "$port" remains occupied."
                exit 0
                ;;
        esac
    fi

    # Security Handshake
    [ ! -f ~/.vnc/passwd ] && {
        log_warn "Security credentials missing. Initializing..."
        mkdir -p ~/.vnc
        echo "password" | vncpasswd -f > ~/.vnc/passwd
        chmod 600 ~/.vnc/passwd
    }

    # Optimization Injection
    export PULSE_SERVER=127.0.0.1 # Prepare for audio routing if needed
    
    # Engine Launch
    log_info "Igniting XFCE Core..."
trap "vncserver -kill :${display_num}; exit 0" SIGTERM SIGINT
    vncserver :"$display_num" \
        -geometry "$DEFAULT_VNC_GEOMETRY" \
        -depth "$DEFAULT_VNC_DEPTH" \
        -name "$DEFAULT_VNC_NAME" \
        -localhost no >/dev/null 2>&1

    # Stability Watchdog
    for i in 1 2 3 4 5; do
        if is_port_open "$port"; then
            log_success "CYBEROS ENGINE ONLINE"
            echo -e "${CYAN}--------------------------------------------------${NC}"
            echo -e "${GREEN}VNC Portal:${NC}   localhost:"$port"
            echo -e "${GREEN}Display:${NC}      :"$display_num"
            echo -e "${GREEN}Environment:${NC}  XFCE4"
            echo -e "${CYAN}--------------------------------------------------${NC}"
            
            if [ "$WEB_AUTO_START" = true ]; then
                log_info "Igniting Web Dashboard..."
                cd "$CYBEROS_BASE" && npm run dev >/dev/null 2>&1 &
            fi
            return 0
        fi
        sleep 1
    done

    log_error "Engine failed to stabilize. Check logs in "$CYBEROS_LOG_DIR"
    exit 1
}

# Main Execution Flow
header
autonomous_doctor
launch_session "${1:-"$DEFAULT_VNC_PORT"}"
exit 0
