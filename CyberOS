#!/bin/bash

# CyberOS VNC Launcher
source "$(dirname "$0")/lib/utils.sh"

log_info "Checking for CyberOS updates..."
git pull --quiet || log_error "Could not fetch updates. Continuing..."

if [ -z "$1" ]; then
    log_error "No port specified. Usage: ./CyberOS [port]"
    exit 1
fi

PORT=$1
# Map port to VNC display number
DISPLAY_NUM=$((PORT - 5900))
[ "$DISPLAY_NUM" -lt 0 ] && DISPLAY_NUM=$PORT

log_info "Starting CyberOS on port $PORT (Display :$DISPLAY_NUM)..."

# Ensure core dependencies exist
check_dependency vncserver || exit 1

# Kill existing vncserver on this display, if any
vncserver -kill :$DISPLAY_NUM &>/dev/null

# Start the VNC Server with the XFCE desktop
log_info "Initializing VNC server..."
vncserver :$DISPLAY_NUM -geometry 1280x720 -depth 24 &>/dev/null

# Verify if the port is listening
sleep 2
if lsof -Pi :$PORT -sTCP:LISTEN -t >/dev/null ; then
    log_info "BOOM! CyberOS is live."
    echo -e "[>] Connect your VNC viewer to <your-ip>:$PORT"
else
    log_error "VNC server failed to start on port $PORT."
    exit 1
fi
