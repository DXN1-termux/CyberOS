#!/bin/bash
set -e
# ==============================================================================
# CyberOS Launcher
# ==============================================================================

CYBEROS_BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${CYBEROS_BASE}/lib/utils.sh"

PORT="${1:-5901}"
DISPLAY_NUM=$((PORT - 5900))

if is_port_open "$PORT"; then
    log_warn "Port $PORT is already in use."
    exit 1
fi

log_info "Launching VNC on port $PORT..."
vncserver :"$DISPLAY_NUM" -depth 24 -name "CyberOS" -localhost no
log_success "VNC session started on port $PORT."
