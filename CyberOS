#!/bin/bash
# ==============================================================================
# CyberOS Launcher - Self-Healing Session Manager
# ==============================================================================

CYBEROS_BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CYBEROS_BASE/lib/utils.sh"

log_info "Initializing CyberOS Environment..."

# 1. Update Check
git -C "$CYBEROS_BASE" pull --quiet &>/dev/null || log_warn "Auto-update check failed. Skipping."

# 2. Input Validation
PORT=$1
if [ -z "$PORT" ] || ! [[ "$PORT" =~ ^[0-9]+$ ]]; then
    log_error "Usage: ./CyberOS [port]"
    log_info "Example: ./CyberOS 5901"
    exit 1
fi

# 3. Environment Sanitization
DISPLAY_NUM=$((PORT - 5900))
[ "$DISPLAY_NUM" -lt 0 ] && DISPLAY_NUM=$PORT

# Verify dependencies
ESSENTIALS=("vncserver" "xfce4-session" "lsof")
for tool in "${ESSENTIALS[@]}"; do
    if ! command -v "$tool" &>/dev/null; then
        log_error "Critical tool '$tool' is missing."
        log_info "Attempting automated repair..."
        ./setup.sh || { log_error "Self-repair failed. Run ./wizard.sh manually."; exit 1; }
        break
    fi
done

# 4. Session Recovery & Conflict Resolution
if is_port_open "$PORT"; then
    log_warn "Port $PORT is already in use."
    read -p "[?] Kill existing VNC session on display :$DISPLAY_NUM? (y/N): " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        log_info "Cleaning display :$DISPLAY_NUM..."
        vncserver -kill :"$DISPLAY_NUM" &>/dev/null
        rm -rf /tmp/.X"$DISPLAY_NUM"-lock /tmp/.X11-unix/X"$DISPLAY_NUM" &>/dev/null
        sleep 1
    else
        log_info "Exiting to prevent session corruption."
        exit 0
    fi
fi

# 5. Launch Protocol
log_info "Launching CyberOS on port $PORT (Display :$DISPLAY_NUM)..."

# Ensure VNC password exists
[ ! -f ~/.vnc/passwd ] && {
    log_warn "VNC password missing. Generating default 'password'..."
    mkdir -p ~/.vnc
    echo "password" | vncpasswd -f > ~/.vnc/passwd
    chmod 600 ~/.vnc/passwd
}

# Start VNC Server with standard parameters for universal compatibility
vncserver :"$DISPLAY_NUM" -depth 24 -name "CyberOS" -localhost no &>/dev/null

# 6. Health Verification Loop
log_info "Verifying session integrity..."
for i in {1..5}; do
    if is_port_open "$PORT"; then
        log_success "CYBEROS IS LIVE!"
        echo -e "${CYAN}--------------------------------------------------${NC}"
        echo -e "${GREEN}VNC Address:${NC} localhost:$PORT"
        echo -e "${GREEN}Display:${NC}     :$DISPLAY_NUM"
        echo -e "${GREEN}Password:${NC}    password (default)"
        echo -e "${CYAN}--------------------------------------------------${NC}"
        exit 0
    fi
    sleep 1
done

log_error "VNC Server failed to bind to port $PORT."
log_info "Check logs at: ~/.vnc/localhost:$DISPLAY_NUM.log"
exit 1
